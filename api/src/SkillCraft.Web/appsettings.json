{
  "AllowedHosts": "*",
  "Api": {
    "Contact": {
      "Email": "francispion@hotmail.com",
      "Name": "Francis Pion",
      "Url": "https://www.francispion.ca"
    },
    "Description": "SkillCraft management Web application.",
    "Environments": [ "Development" ],
    "JwtBearer": {
      "Description": "Enter your token in the input below.",
      "Enabled": true
    },
    "License": {
      "Name": "Use under MIT",
      "Url": "https://github.com/Utar94/SkillCraft/blob/develop/LICENSE"
    },
    "OperationFilters": [
      "SkillCraft.Web.AddHeaderParameters, SkillCraft.Web, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null"
    ],
    "Title": "SkillCraft API",
    "Version": "1.0.0"
  },
  "Cors": {
    "AllowedHeaders": [ "Authorization", "Content-Type" ],
    "AllowedMethods": [ "DELETE", "GET", "PATCH", "POST", "PUT" ]
  },
  "Identity": {
    "SignIn": {
      "RequireConfirmedEmail": true
    },
    "User": {
      "RequireUniqueEmail": true
    }
  },
  "SendGrid": {
    "Sender": {
      "Address": "skillcraft.no-reply@francispion.ca",
      "DisplayName": "SkillCraft"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
